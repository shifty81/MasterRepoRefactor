{
  "projectId": "novaforge",
  "displayName": "NovaForge",
  "version": 1,
  "repoRoot": ".",
  "engineRoot": "engine",
  "editorRoot": "editor",
  "clientRoot": "cpp_client",
  "serverRoot": "cpp_server",
  "dataRoot": "data",
  "docsRoot": "docs",
  "integrationsRoot": "integrations/arbiter",
  "buildTargets": [
    {
      "id": "editor",
      "displayName": "Atlas Editor",
      "command": "cmake --build build --target AtlasEditor"
    },
    {
      "id": "client",
      "displayName": "NovaForge Client",
      "command": "cmake --build build --target NovaForgeClient"
    },
    {
      "id": "server",
      "displayName": "NovaForge Server",
      "command": "cmake --build build --target NovaForgeServer"
    },
    {
      "id": "tests",
      "displayName": "Project Tests",
      "command": "ctest --test-dir build --output-on-failure"
    }
  ],
  "bridge": {
    "transport": "http",
    "baseUrl": "http://127.0.0.1:8005",
    "timeoutMs": 8000
  },
  "capabilities": [
    "project.info",
    "build.run",
    "files.open",
    "analysis.lint",
    "editor.selection.query",
    "editor.tools.list",
    "editor.tools.run",
    "assets.generate.request",
    "logs.stream"
  ],
  "safety": {
    "allowWriteActions": false,
    "requireReviewForCodegen": true,
    "whitelistedToolActions": [
      "validate_data",
      "run_pcg_preview",
      "open_scene",
      "focus_entity",
      "regenerate_schemas"
    ]
  }
}