# Intake — staging area gitignore
# Binary and archive files placed here for processing are kept LOCAL ONLY.
# Once processed through process_intake.py they are moved to canonical locations.

# --- Archive formats ---
*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz
*.tar.bz2
*.tar.xz
*.gz
*.bz2
*.xz

# --- Windows installer / macOS disk image / Linux package ---
*.exe
*.msi
*.dmg
*.pkg
*.deb
*.rpm
*.appimage

# --- 3-D source assets ---
*.fbx
*.obj
*.dae
*.blend
*.max
*.mb
*.ma

# --- Source art ---
*.psd
*.ai
*.sketch
*.xcf
*.kra

# --- Video ---
*.mp4
*.avi
*.mov
*.mkv
*.webm
*.wmv
*.flv

# --- Audio blobs ---
*.wav
*.mp3
*.ogg
*.flac
*.aac
*.wma

# --- But DO track lightweight text / code drops for versioning ---
!*.md
!*.txt
!*.log
!*.json
!*.yaml
!*.yml
!*.h
!*.hpp
!*.cpp
!*.cs
!*.py
!*.sh
!*.bat
!*.cmake
!.gitignore
