	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 BridgeServiceIntegrationTest
.PHONY : BridgeServiceIntegrationTest

# fast build rule for target.
BridgeServiceIntegrationTest/fast:
	$(MAKE) $(MAKESILENT) -f Tests/Integration/CMakeFiles/BridgeServiceIntegrationTest.dir/build.make Tests/Integration/CMakeFiles/BridgeServiceIntegrationTest.dir/build
.PHONY : BridgeServiceIntegrationTest/fast

