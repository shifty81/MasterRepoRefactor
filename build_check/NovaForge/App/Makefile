	cd /home/runner/work/MasterRepoRefactor/MasterRepoRefactor/build_check && $(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles/Makefile.cmake 0
