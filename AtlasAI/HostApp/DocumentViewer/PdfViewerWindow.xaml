<Window x:Class="AtlasAIHost.PdfViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="PDF Viewer" Height="800" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PanelBgBrush}"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar showing the file name -->
        <TextBlock Grid.Row="0" Name="FileNameLabel"
                   FontWeight="Bold" FontSize="13"
                   Margin="8,6,8,4"
                   TextTrimming="CharacterEllipsis"/>

        <!-- WebView2 renders the PDF read-only -->
        <wv2:WebView2 Grid.Row="1" Name="PdfWebView"/>
    </Grid>
</Window>
