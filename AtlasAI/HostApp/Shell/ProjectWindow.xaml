<Window x:Class="AtlasAIHost.ProjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AtlasAI Project" Height="850" Width="1200"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource DarkBgBrush}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>               <!-- Row 0: Menu Bar -->
            <RowDefinition Height="Auto"/>               <!-- Row 1: Toolbar -->
            <RowDefinition Height="*" MinHeight="150"/>  <!-- Row 2: Main content -->
            <RowDefinition Height="5"/>                  <!-- Row 3: Splitter -->
            <RowDefinition Height="220" MinHeight="100"/><!-- Row 4: Bottom tabs -->
            <RowDefinition Height="Auto"/>               <!-- Row 5: Status Bar -->
        </Grid.RowDefinitions>

        <!-- ==================== ROW 0: MENU BAR ==================== -->
        <Menu Grid.Row="0"
              Background="{StaticResource PanelBgBrush}"
              Foreground="{StaticResource ForegroundBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="0,0,0,1"
              Padding="2,1">
            <MenuItem Header="_File" Foreground="{StaticResource ForegroundBrush}">
                <MenuItem Header="📂 Open Folder…"/>
                <MenuItem Header="📄 Open File…"/>
                <Separator/>
                <MenuItem Header="Exit" InputGestureText="Alt+F4"/>
            </MenuItem>
            <MenuItem Header="_Edit" Foreground="{StaticResource ForegroundBrush}">
                <MenuItem Header="⎌ Undo"   InputGestureText="Ctrl+Z"/>
                <MenuItem Header="↻ Redo"   InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="✂ Cut"    InputGestureText="Ctrl+X"/>
                <MenuItem Header="📋 Copy"  InputGestureText="Ctrl+C"/>
                <MenuItem Header="📄 Paste" InputGestureText="Ctrl+V"/>
            </MenuItem>
            <MenuItem Header="_View" Foreground="{StaticResource ForegroundBrush}">
                <MenuItem Header="💬 Toggle Chat Panel"/>
                <MenuItem Header="⌨ Command Palette" InputGestureText="Ctrl+Shift+P"/>
            </MenuItem>
            <MenuItem Header="_Git" Foreground="{StaticResource ForegroundBrush}">
                <MenuItem Header="✓ Commit…"  Click="Commit_Click"/>
                <MenuItem Header="⎇ Branch"   Click="Branch_Click"/>
                <Separator/>
                <MenuItem Header="⬆ Push"     Click="Push_Click"/>
                <MenuItem Header="⬇ Pull"     Click="Pull_Click"/>
                <MenuItem Header="📋 Log"      Click="Log_Click"/>
            </MenuItem>
            <MenuItem Header="_Build" Foreground="{StaticResource ForegroundBrush}">
                <MenuItem Header="🔨 Build"  Click="Build_Click"  InputGestureText="Ctrl+B"/>
                <MenuItem Header="▶ Run"     Click="Run_Click"    InputGestureText="F5"/>
                <MenuItem Header="✅ Test"    Click="Test_Click"   InputGestureText="Ctrl+T"/>
            </MenuItem>
            <MenuItem Header="_AI" Foreground="{StaticResource ForegroundBrush}">
                <MenuItem Header="🤖 Auto-Build Next Task"/>
                <MenuItem Header="💬 Open Chat"/>
                <Separator/>
                <MenuItem Header="🔄 Rebuild Archive"/>
            </MenuItem>
            <MenuItem Header="_Help" Foreground="{StaticResource ForegroundBrush}">
                <MenuItem Header="📖 AtlasAI Docs"/>
                <Separator/>
                <MenuItem Header="ℹ About AtlasAI"/>
            </MenuItem>
        </Menu>

        <!-- ==================== ROW 1: TOOLBAR ==================== -->
        <Border Grid.Row="1"
                Background="{StaticResource PanelBgBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,4">
                <TextBlock Text="Phase:" VerticalAlignment="Center" Margin="0,0,4,0"
                           Foreground="{StaticResource DimForegroundBrush}"/>
                <ComboBox Name="PhaseSelector" Width="120" Margin="0,0,8,0"/>
                <Separator Width="1" Margin="4,2"/>
                <TextBlock Text="Persona:" VerticalAlignment="Center" Margin="0,0,4,0"
                           Foreground="{StaticResource DimForegroundBrush}"/>
                <ComboBox Name="PersonaSelector" Width="120" Margin="0,0,8,0"
                          SelectionChanged="PersonaSelector_SelectionChanged"/>
                <Separator Width="1" Margin="4,2"/>
                <Button Content="✓ Commit"  Margin="2,0" Click="Commit_Click"/>
                <Button Content="⎇ Branch"  Margin="2,0" Click="Branch_Click"/>
                <Button Content="⬆ Push"    Margin="2,0" Click="Push_Click"/>
                <Button Content="⬇ Pull"    Margin="2,0" Click="Pull_Click"/>
                <Button Content="📋 Log"    Margin="2,0" Click="Log_Click"/>
                <Separator Width="1" Margin="4,2"/>
                <Button Content="🔨 Build"  Margin="2,0" Click="Build_Click"/>
                <Button Content="▶ Run"     Margin="2,0" Click="Run_Click"/>
                <Button Content="✅ Test"    Margin="2,0" Click="Test_Click"/>
                <Separator Width="1" Margin="4,2"/>
                <TextBlock Text="Voice:" VerticalAlignment="Center" Margin="0,0,4,0"
                           Foreground="{StaticResource DimForegroundBrush}"/>
                <ComboBox Name="VoiceSelector" Width="150" Margin="0,0,8,0">
                    <ComboBoxItem Content="British_Female" IsSelected="True"/>
                    <ComboBoxItem Content="British_Male"/>
                    <ComboBoxItem Content="American_Female"/>
                    <ComboBoxItem Content="American_Male"/>
                </ComboBox>
            </WrapPanel>
        </Border>

        <!-- ==================== ROW 2: MAIN CONTENT ==================== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="200"/>  <!-- Chat panel -->
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="150"/>   <!-- Suggestions panel -->
            </Grid.ColumnDefinitions>

            <!-- ── Chat Panel ── -->
            <Border Grid.Column="0"
                    Background="{StaticResource AIPanelBgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="🤖 AI Chat" FontWeight="Bold"
                               FontSize="13" Margin="0,4,0,6"/>
                    <ListBox Grid.Row="1" Name="ChatDisplay"
                             Background="{StaticResource AIPanelBgBrush}"
                             BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    <Border Grid.Row="2"
                            Background="{StaticResource PanelBgBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="4"
                            Padding="6" Margin="0,6,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Name="ChatInput" Margin="0,0,5,0"/>
                            <Button  Grid.Column="1" Content="Send ➤" Width="70" Margin="0,0,5,0"
                                     Background="{StaticResource AccentBrush}"
                                     Foreground="{StaticResource HighlightTextBrush}"
                                     Click="SendButton_Click"/>
                            <Button  Grid.Column="2" Content="🎤 Mic" Width="60"
                                     Click="MicButton_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          Background="{StaticResource BorderBrush}"/>

            <!-- ── Suggestions Panel ── -->
            <Border Grid.Column="2"
                    Background="{StaticResource PanelBgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Suggestions / Roadmap"
                               FontWeight="Bold" FontSize="13" Margin="0,4,0,6"/>
                    <ListBox Grid.Row="1" Name="SuggestionsListBox"
                             Background="{StaticResource PanelBgBrush}"
                             BorderThickness="0"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="✅ Approve" Width="90" Margin="0,0,5,0"
                                Click="ApproveSuggestion_Click"/>
                        <Button Content="➡ Move" Width="70"
                                Click="MoveSuggestion_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ==================== ROW 3: SPLITTER ==================== -->
        <GridSplitter Grid.Row="3" Height="5"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"
                      Background="{StaticResource BorderBrush}"/>

        <!-- ==================== ROW 4: BOTTOM TABS ==================== -->
        <TabControl Grid.Row="4" Name="BottomTabControl"
                    Background="{StaticResource PanelBgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
            <TabItem Header="Project Files">
                <TreeView Name="ProjectFilesTree" AllowDrop="True"
                          Drop="ProjectFilesTree_Drop"
                          MouseDoubleClick="ProjectFilesTree_MouseDoubleClick"
                          Background="{StaticResource PanelBgBrush}"
                          BorderThickness="0"/>
            </TabItem>
            <TabItem Header="Build Output">
                <TextBox Name="BuildOutputBox"
                         IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Courier New" FontSize="11" AcceptsReturn="True"
                         Background="{StaticResource DarkBgBrush}"
                         BorderThickness="0"/>
            </TabItem>
            <TabItem Header="Console">
                <TabControl Name="ConsoleTabControl"
                            Background="{StaticResource PanelBgBrush}"
                            BorderThickness="0">
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="LLM" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Button Content="Copy" Padding="4,1" FontSize="10"
                                        Click="CopyLlmConsole_Click"
                                        ToolTip="Copy LLM log to clipboard"/>
                            </StackPanel>
                        </TabItem.Header>
                        <TextBox Name="LlmConsoleBox" IsReadOnly="True" TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Courier New" FontSize="11" AcceptsReturn="True"
                                 Background="{StaticResource DarkBgBrush}" BorderThickness="0"/>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="App" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Button Content="Copy" Padding="4,1" FontSize="10"
                                        Click="CopyAppConsole_Click"
                                        ToolTip="Copy App log to clipboard"/>
                            </StackPanel>
                        </TabItem.Header>
                        <TextBox Name="AppConsoleBox" IsReadOnly="True" TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Courier New" FontSize="11" AcceptsReturn="True"
                                 Background="{StaticResource DarkBgBrush}" BorderThickness="0"/>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Server" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Button Content="Copy" Padding="4,1" FontSize="10"
                                        Click="CopyServerConsole_Click"
                                        ToolTip="Copy Server log to clipboard"/>
                            </StackPanel>
                        </TabItem.Header>
                        <TextBox Name="ServerConsoleBox" IsReadOnly="True" TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Courier New" FontSize="11" AcceptsReturn="True"
                                 Background="{StaticResource DarkBgBrush}" BorderThickness="0"/>
                    </TabItem>
                </TabControl>
            </TabItem>
        </TabControl>

        <!-- ==================== ROW 5: STATUS BAR ==================== -->
        <Border Grid.Row="5"
                Background="{StaticResource TaskbarBgBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Height="28">
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse Grid.Column="0" Name="ServerStatusDot"
                         Width="10" Height="10" Fill="Gray"
                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBlock Grid.Column="1" Name="ServerStatusText" Text="Server: …"
                           VerticalAlignment="Center" FontSize="11" Margin="0,0,10,0"
                           Foreground="{StaticResource DimForegroundBrush}"/>
                <Button Grid.Column="2" Name="StartServerButton" Content="▶ Server"
                        Padding="6,2" FontSize="11" Margin="0,0,12,0"
                        Click="StartServer_Click"/>
                <TextBlock Grid.Column="3" Name="CpuMemStatus" Text="CPU: -- | Mem: --"
                           VerticalAlignment="Center" FontSize="11"
                           Foreground="{StaticResource DimForegroundBrush}"/>
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🤖" FontSize="14" Margin="6,0" ToolTip="AI Server"/>
                    <TextBlock Text="🔔" FontSize="14" Margin="6,0" ToolTip="Notifications"/>
                    <TextBlock Text="⚙" FontSize="14" Margin="6,0" ToolTip="Settings"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
