<Window x:Class="AtlasAIHost.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AtlasAI — Choose Mode"
        Height="500" Width="820"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource DarkBgBrush}"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="*"/>     <!-- cards -->
            <RowDefinition Height="Auto"/>  <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,36,0,28">
            <TextBlock Text="⬡  AtlasAI"
                       FontSize="32" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Choose your assistant"
                       FontSize="14"
                       Foreground="{StaticResource DimForegroundBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <!-- ── Cards ── -->
        <Grid Grid.Row="1" Margin="40,0,40,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ArbiterAI card -->
            <Border Grid.Column="0"
                    Background="{StaticResource PanelBgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="28,24">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Direction="270"
                                      ShadowDepth="4" BlurRadius="12" Opacity="0.4"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🏛"
                               FontSize="40" HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="1" Text="ArbiterAI"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14"/>

                    <StackPanel Grid.Row="2" Margin="0,0,0,20">
                        <TextBlock Text="Project-based AI assistant"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource ForegroundBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource DimForegroundBrush}"
                                   TextWrapping="Wrap" LineHeight="20">
                            <Run>• Chat, code generation &amp; review</Run><LineBreak/>
                            <Run>• Project workspace &amp; file tree</Run><LineBreak/>
                            <Run>• Git integration (commit / push / pull)</Run><LineBreak/>
                            <Run>• Build, run &amp; test loop</Run><LineBreak/>
                            <Run>• Voice TTS / STT</Run><LineBreak/>
                            <Run>• Switchable AI personas</Run>
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Row="3"
                            Name="LaunchArbiterBtn"
                            Content="Launch ArbiterAI"
                            FontSize="14" FontWeight="SemiBold"
                            Padding="12,10"
                            Background="{StaticResource AccentBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="LaunchArbiterAI_Click"/>
                </Grid>
            </Border>

            <!-- AtlasAI Engine card -->
            <Border Grid.Column="2"
                    Background="{StaticResource PanelBgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="28,24">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Direction="270"
                                      ShadowDepth="4" BlurRadius="12" Opacity="0.4"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="⚙"
                               FontSize="40" HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="1" Text="AtlasAI Engine"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14"/>

                    <StackPanel Grid.Row="2" Margin="0,0,0,20">
                        <TextBlock Text="Full agentic development platform"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource ForegroundBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource DimForegroundBrush}"
                                   TextWrapping="Wrap" LineHeight="20">
                            <Run>• 200+ tools across 42 modules</Run><LineBreak/>
                            <Run>• Agentic plan→execute→reflect loop</Run><LineBreak/>
                            <Run>• 13 AI specialist personas</Run><LineBreak/>
                            <Run>• 12 LLM backends (Ollama, Claude, Gemini…)</Run><LineBreak/>
                            <Run>• Docker, CI/CD, deploy, DB, image/audio</Run><LineBreak/>
                            <Run>• Self-build &amp; autonomous roadmap execution</Run>
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Row="3"
                            Name="LaunchEngineBtn"
                            Content="Launch AtlasAI Engine"
                            FontSize="14" FontWeight="SemiBold"
                            Padding="12,10"
                            Background="{StaticResource AccentBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="LaunchAtlasAIEngine_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Footer ── -->
        <TextBlock Grid.Row="2"
                   Text="Arbiter Engine requires Python 3.10+ and a running LLM backend (e.g. Ollama). Run AIEngine/AtlasAIEngine/setup_modules.py first."
                   FontSize="11"
                   Foreground="{StaticResource DimForegroundBrush}"
                   HorizontalAlignment="Center"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Margin="40,0,40,18"/>
    </Grid>
</Window>
