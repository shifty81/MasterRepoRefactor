<Window x:Class="AtlasAIHost.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AtlasAI Settings"
        Width="560" Height="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource DarkBgBrush}"
        Foreground="{DynamicResource ForegroundBrush}">

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush"   Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Foreground"    Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Margin"        Value="0,0,0,10"/>
            <Setter Property="Padding"       Value="6,4"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground"    Value="{DynamicResource DimForegroundBrush}"/>
            <Setter Property="Padding"       Value="0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"    Value="{DynamicResource ControlBgBrush}"/>
            <Setter Property="Foreground"    Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush"   Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding"       Value="4,3"/>
            <Setter Property="Height"        Value="26"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background"    Value="{DynamicResource ControlBgBrush}"/>
            <Setter Property="Foreground"    Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush"   Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Height"        Value="26"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"    Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Margin"        Value="0,4"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"    Value="{DynamicResource ButtonBgBrush}"/>
            <Setter Property="Foreground"    Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush"   Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding"       Value="10,4"/>
            <Setter Property="Height"        Value="28"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True" Margin="12">

        <!-- Footer buttons — docked to bottom -->
        <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="💾 Save"   Width="90" Margin="0,0,8,0"
                        IsDefault="True" Click="Save_Click"/>
                <Button Content="Cancel"    Width="80"
                        IsCancel="True"  Click="Cancel_Click"/>
            </StackPanel>
        </Border>

        <!-- Scrollable settings content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ── Server Ports ─────────────────────────────────────────── -->
                <GroupBox Header="🌐 Server Ports">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Content="PythonBridge port:"
                               VerticalAlignment="Center"/>
                        <TextBox Name="BridgePortBox" Grid.Row="0" Grid.Column="1"
                                 ToolTip="Port for ArbiterAI (fastapi_bridge.py). Default: 8000"/>
                        <Label Grid.Row="1" Grid.Column="0" Content="AtlasAI Engine port:"
                               VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBox Name="EnginePortBox" Grid.Row="1" Grid.Column="1"
                                 Margin="0,6,0,0"
                                 ToolTip="Port for AtlasAI Engine (server.py). Default: 8001"/>
                    </Grid>
                </GroupBox>

                <!-- ── LLM Backend ──────────────────────────────────────────── -->
                <GroupBox Header="🧠 LLM Backend">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Content="Backend URL:"
                               VerticalAlignment="Center"/>
                        <TextBox Name="LlmUrlBox" Grid.Row="0" Grid.Column="1"
                                 ToolTip="e.g. http://localhost:11434 for Ollama"/>
                        <Label Grid.Row="1" Grid.Column="0" Content="Default model:"
                               VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBox Name="LlmModelBox" Grid.Row="1" Grid.Column="1"
                                 Margin="0,6,0,0"
                                 ToolTip="Model name passed to /chat. 'auto' lets the backend choose."/>
                    </Grid>
                </GroupBox>

                <!-- ── Voice ────────────────────────────────────────────────── -->
                <GroupBox Header="🔊 Voice &amp; TTS">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Content="Default voice:"
                               VerticalAlignment="Center"/>
                        <ComboBox Name="VoiceCombo" Grid.Row="0" Grid.Column="1">
                            <ComboBoxItem Content="British_Female"/>
                            <ComboBoxItem Content="British_Male"/>
                            <ComboBoxItem Content="American_Female"/>
                            <ComboBoxItem Content="American_Male"/>
                        </ComboBox>
                        <CheckBox Name="TtsEnabledCheck" Grid.Row="1" Grid.ColumnSpan="2"
                                  Content="Enable TTS (AI responses read aloud)"
                                  Margin="0,8,0,0"/>
                    </Grid>
                </GroupBox>

                <!-- ── Git Identity ──────────────────────────────────────────── -->
                <GroupBox Header="🔀 Git Identity">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Grid.Column="0" Content="Author name:"
                               VerticalAlignment="Center"/>
                        <TextBox Name="GitNameBox" Grid.Row="0" Grid.Column="1"
                                 ToolTip="Used in git commits made by Arbiter"/>
                        <Label Grid.Row="1" Grid.Column="0" Content="Author email:"
                               VerticalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBox Name="GitEmailBox" Grid.Row="1" Grid.Column="1"
                                 Margin="0,6,0,0"/>
                    </Grid>
                </GroupBox>

                <!-- ── Library Paths ─────────────────────────────────────────── -->
                <GroupBox Header="📚 Library Paths (Archive indexing)">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="80"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="Paths indexed by the Archive (one per line):"
                                   Foreground="{DynamicResource DimForegroundBrush}"
                                   FontSize="11" Margin="0,0,0,4"/>
                        <TextBox Name="LibraryPathsBox" Grid.Row="1"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 Height="80"
                                 ToolTip="Each line is a directory or file path to include in the Archive."/>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="＋ Add Path" Margin="0,0,6,0"
                                    Click="AddLibraryPath_Click"/>
                            <Button Content="✕ Remove Selected" Click="RemoveLibraryPath_Click"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- ── Misc ─────────────────────────────────────────────────── -->
                <GroupBox Header="⚙️ Miscellaneous">
                    <StackPanel>
                        <CheckBox Name="ChatLoggingCheck"
                                  Content="Log chat history to disk"/>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
