<Window x:Class="AtlasAIHost.WorkspaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AtlasAI Workspace" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource PanelBgBrush}">
    <Grid Background="{StaticResource PanelBgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" MinWidth="150"/>  <!-- Project list panel -->
            <ColumnDefinition Width="5"/>                    <!-- vertical splitter -->
            <ColumnDefinition Width="*"/>                    <!-- Project summary panel -->
        </Grid.ColumnDefinitions>

        <!-- Project List Panel -->
        <Grid Grid.Column="0" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- header -->
                <RowDefinition Height="*"/>      <!-- list fills space -->
                <RowDefinition Height="Auto"/>   <!-- Create button -->
                <RowDefinition Height="Auto"/>   <!-- Open button -->
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Projects" FontWeight="Bold" FontSize="16" Margin="0,0,0,5"/>
            <ListBox Grid.Row="1" Name="ProjectListBox" AllowDrop="True"
                     Drop="ProjectListBox_Drop"
                     SelectionChanged="ProjectListBox_SelectionChanged"/>
            <Button Grid.Row="2" Content="Create Project" Margin="0,5,0,2" Click="CreateProject_Click"/>
            <Button Grid.Row="3" Content="Open Project"   Margin="0,2,0,0" Click="OpenProject_Click"/>
        </Grid>

        <!-- Vertical splitter between project list and summary -->
        <GridSplitter Grid.Column="1" Width="5"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- Project Summary Panel -->
        <Grid Grid.Column="2" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- header -->
                <RowDefinition Height="*"/>      <!-- summary fills space -->
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Project Overview" FontWeight="Bold" FontSize="16" Margin="0,0,0,5"/>
            <TextBox Grid.Row="1" Name="ProjectSummaryBox" IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
        </Grid>
    </Grid>
</Window>
