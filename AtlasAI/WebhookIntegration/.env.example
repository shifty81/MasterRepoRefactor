# GitHub Configuration
# Personal Access Token with repo and issues scopes
GITHUB_TOKEN=ghp_your_token_here
# The owner (user or org) of the repository where issues will be created
GITHUB_OWNER=your-org-or-user
# The repository name where issues will be created
GITHUB_REPO=your-repo-name

# Server Configuration
PORT=3000

# Jira Integration
# Secret used to verify incoming Jira webhook signatures
JIRA_WEBHOOK_SECRET=your-jira-webhook-secret
# Label on Jira issues that triggers delegation to Copilot (default: copilot)
JIRA_TRIGGER_LABEL=copilot

# Azure Boards Integration
# Shared secret configured in Azure Boards service hook
AZURE_BOARDS_WEBHOOK_SECRET=your-azure-boards-webhook-secret
# Tag on Azure work items that triggers delegation to Copilot (default: copilot)
AZURE_BOARDS_TRIGGER_TAG=copilot

# Linear Integration
# Secret used to verify incoming Linear webhook signatures
LINEAR_WEBHOOK_SECRET=your-linear-webhook-secret
# Label on Linear issues that triggers delegation to Copilot (default: copilot)
LINEAR_TRIGGER_LABEL=copilot
