<Window x:Class="AtlasAI.Shell.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AtlasAI Shell" Height="900" Width="1400"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Row 0: Menu Bar -->
            <RowDefinition Height="Auto"/>   <!-- Row 1: Toolbar -->
            <RowDefinition Height="*"/>      <!-- Row 2: Main Content -->
            <RowDefinition Height="5"/>      <!-- Row 3: Splitter -->
            <RowDefinition Height="180" MinHeight="80"/> <!-- Row 4: Bottom Panel -->
            <RowDefinition Height="Auto"/>   <!-- Row 5: Status Bar -->
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Padding="2,1">
            <MenuItem Header="_File">
                <MenuItem Header="Open Workspace…"/>
                <MenuItem Header="Save Workspace"/>
                <Separator/>
                <MenuItem Header="Exit"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Chat Panel" IsCheckable="True" IsChecked="True"/>
                <MenuItem Header="Logs Panel" IsCheckable="True" IsChecked="True"/>
                <MenuItem Header="Build Panel" IsCheckable="True" IsChecked="True"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="Settings…"/>
                <MenuItem Header="Workspace Manager…"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About AtlasAI Shell"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBar Grid.Row="1">
            <Button Content="▶ Run" ToolTip="Run current session"/>
            <Button Content="⏹ Stop" ToolTip="Stop current session"/>
            <Separator/>
            <Button Content="📂 Open" ToolTip="Open workspace"/>
            <Button Content="💾 Save" ToolTip="Save workspace"/>
        </ToolBar>

        <!-- Main Content Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="150"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Chat -->
            <Border Grid.Column="0" BorderThickness="0,0,1,0">
                <StackPanel>
                    <TextBlock Text="AI Chat" FontSize="14" FontWeight="Bold" Margin="8,8,8,4"/>
                    <TextBox x:Name="ChatInputBox" Margin="8,0,8,4"
                             AcceptsReturn="True" Height="80" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             ToolTip="Enter message to AI"/>
                    <Button Content="Send" Margin="8,0,8,8" Click="SendChat_Click"/>
                    <ScrollViewer Height="400" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ChatOutputBlock" Margin="8,0,8,0"
                                   TextWrapping="Wrap" Text="Chat output appears here."/>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Vertical Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

            <!-- Right Panel: Build/Workspace -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="200" MinHeight="80"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0">
                    <StackPanel Margin="8">
                        <TextBlock Text="Workspace" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Text="No workspace loaded." x:Name="WorkspaceStatusBlock" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"/>
                <Border Grid.Row="2">
                    <StackPanel Margin="8">
                        <TextBlock Text="Build Output" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                        <ScrollViewer Height="150" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="BuildOutputBlock" TextWrapping="Wrap"
                                       Text="Build output appears here." FontFamily="Consolas"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Horizontal Splitter -->
        <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch"/>

        <!-- Bottom Panel: Logs -->
        <Border Grid.Row="4">
            <StackPanel>
                <TextBlock Text="Logs" FontSize="12" FontWeight="Bold" Margin="8,4,8,4"/>
                <ScrollViewer Height="140" VerticalScrollBarVisibility="Auto" Margin="8,0,8,4">
                    <TextBlock x:Name="LogOutputBlock" TextWrapping="Wrap"
                               FontFamily="Consolas" FontSize="11"
                               Text="Log output appears here."/>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <StatusBar Grid.Row="5">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
