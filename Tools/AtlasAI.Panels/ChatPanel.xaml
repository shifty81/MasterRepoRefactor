<UserControl x:Class="AtlasAI.Panels.ChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="AI Chat" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="ChatHistoryBlock" TextWrapping="Wrap"
                       Text="Chat history appears here." Margin="0,0,0,8"/>
        </ScrollViewer>

        <TextBox Grid.Row="2" x:Name="InputTextBox" AcceptsReturn="True" Height="60"
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,4" ToolTip="Type a message to the AI assistant"/>

        <Button Grid.Row="3" Content="Send Message" Click="Send_Click" HorizontalAlignment="Right"/>
    </Grid>
</UserControl>
