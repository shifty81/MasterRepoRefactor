<UserControl x:Class="AtlasAI.Panels.LogsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Logs &amp; Telemetry" FontSize="16" FontWeight="Bold"/>
            <Button Content="Clear" Margin="16,0,0,0" Click="Clear_Click"/>
            <Button Content="Export" Margin="4,0,0,0" Click="Export_Click"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      x:Name="LogScroller">
            <TextBlock x:Name="LogTextBlock" TextWrapping="Wrap"
                       FontFamily="Consolas" FontSize="11"
                       Text="Log output appears here." Margin="0,0,0,8"/>
        </ScrollViewer>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="LogStatusBlock" Text="0 entries"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
