<UserControl x:Class="UI.AtlasSuite.Panels.BuilderDebug.BuilderDebugPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <StackPanel>
            <TextBlock Text="Builder Debug" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Text="Selected Part ID"/>
            <TextBox x:Name="SelectedPartTextBox" Text="hull_plate_mk1_a" Margin="0,4,0,8"/>
            <TextBlock Text="Construct ID"/>
            <TextBox x:Name="ConstructIdTextBox" Text="dev_builder_salvage_construct" Margin="0,4,0,8"/>
            <Button Content="Preview Placement" Margin="0,0,0,4"/>
            <Button Content="Commit Placement" Margin="0,0,0,4"/>
            <Button Content="Validate Construct" Margin="0,0,0,4"/>
            <Button Content="Weld Placement" Margin="0,0,0,4"/>
            <Button Content="Apply Test Damage" Margin="0,0,0,8"/>
            <TextBlock Text="Scaffold panel only — wire commands to runtime services." TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>
