<UserControl x:Class="UI.AtlasSuite.Panels.ConstructControl.ConstructControlPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <StackPanel>
            <TextBlock FontSize="18" FontWeight="Bold" Text="Construct Control" />
            <TextBlock Margin="0,8,0,0" Text="Construct ID" />
            <TextBox x:Name="ConstructIdTextBox" Text="dev_ship_starter" />
            <Button Margin="0,12,0,0" Width="160" Height="32" Content="Refresh Snapshot" />
            <TextBlock Margin="0,12,0,0" Text="Cargo / Module snapshot placeholder" />
            <TextBox Height="180" AcceptsReturn="True" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</UserControl>
