# Dependencies
node_modules/
vendor/
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# Build artifacts
dist/
build/
Build/
!Scripts/Build/
!Logs/build/
out/
target/
obj/
bin/
*.o
*.a
*.so
*.dll
*.exe

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs and runtime files
*.pid
*.seed
*.lock
!package-lock.json
!yarn.lock
# Repository-level log directories — files ARE tracked so debug sessions can
# be reviewed in the repo.  Run Scripts/Logging/clear_logs.sh locally once
# issues are resolved.

# Environment and secrets
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# Test coverage
coverage/
.coverage
htmlcov/
.nyc_output/
lcov.info

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Zip archives and binary archives
# Raw archives must never be committed to root or DropBox.
# Integrate their contents and archive the zip in Docs/Archive/ZipFiles/ (or keep locally).
# DropBox/ has its own .gitignore for the same purpose.

# Root-level zip/archive files (keep locally, not in git)
/*.zip
/*.7z
/*.rar
/*.tar
/*.tar.gz
/*.tgz
/*.tar.bz2
/*.tar.xz

# Historical root files (kept for backwards compat with any existing local clones)
MasterRepoRefactor-main.zip
resolve-zip-conflict.bat
New Text Document.txt
