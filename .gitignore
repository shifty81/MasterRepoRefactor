dist/
build/
Build/
!Scripts/Build/
out/
target/
obj/
bin/
*.o
*.a
*.so
*.dll
*.exe

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

