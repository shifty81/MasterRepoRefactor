!NovaForge/Client/logs/.gitkeep
!AtlasAI/AIEngine/AtlasAIEngine/logs/.gitkeep

# Environment and secrets
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# Test coverage
coverage/
.coverage
htmlcov/
.nyc_output/
lcov.info

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Zip archives — all zips are archived in Docs/Archive/ZipFiles/; none should appear at repo root
MasterRepoRefactor-main.zip

# Binary mesh/asset files — not stored in source control.
# Add them locally to NovaForge/Content/Meshes/ after downloading the free placeholder assets.
# See Docs/Art/CHARACTER_PLACEHOLDER_GUIDE.md for download and import instructions.
NovaForge/Content/Meshes/**/*.glb
NovaForge/Content/Meshes/**/*.fbx
NovaForge/Content/Meshes/**/*.obj
NovaForge/Content/Meshes/**/*.gltf
NovaForge/Content/Meshes/**/*.dae
# Keep manifests and .gitkeep files
!NovaForge/Content/Meshes/**/ASSET_MANIFEST.json
!NovaForge/Content/Meshes/**/.gitkeep

